{
    "layer": "top", // Waybar at top layer
    "height": 30, // Waybar height (to be removed for auto height)
    "gtk-layer-shell": "true",
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "custom/scratchpad", "sway/mode"],
    "modules-center": ["custom/music"],
    "modules-right": ["tray", "custom/zypper", "network", "bluetooth", "cpu", "memory", "disk", "temperature#cpu", "temperature#gpu", "backlight", "battery", "battery#bat2", "pulseaudio", "custom/layout", "clock", "idle_inhibitor", "custom/notification"],
    "sway/mode": {
        "format": "´üö´äů {}"
    },
    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name} {icon}",
        "format-icons": {
            "urgent": "ţśź",
            "focused": "ţśź",
            "default": ""
        }
    },
    "custom/zypper": {
        "format": "{} ´ćç",
        "interval": 3600,
        "exec": "zypper lu | grep 'v  |' | wc -l; echo 'packages to update'",
        "exec-if": "exit 0",
        "on-click": "exec alacritty -e sudo sh -c 'zypper ref; zypper dup; pkill -SIGRTMIN+8 waybar'",
        "signal": 8
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        } 
    },
    "bluetooth": {
        "format": "´Őö",
        "format-disabled": "´Őö",
        "format-off": "´Őö",
        "format-on": "´Őö",
        "format-connected": "´Őö {num_connections} {status}",
        "tooltip": "true",
        "tooltip-format": "{controller_address} {status}\n\n{num_connections} connected",
        "tooltip-format-disabled": "{status}",
        "tooltip-format-connected": "{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
    },
    "custom/music": {
        "format": "´Çü  {}",
        "escape": true,
        "interval": 3,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 60
    },
    "tray": {
        "icon-size": 17,
        "spacing": 10
    },
    "clock": {
		"timezone": "Europe/Zurich",
        "format": "´ÇŚ {:%d %b %Y %H:%M:%S}",
        "tooltip-format": "<span color='#35b9ab'><tt><small>{calendar}</small></tt></span>",
        "calendar": {
            "mode-mon-col"      : 4,
            "weeks-pos"         : "left",
            "on-scroll"         : 1,
            "on-click-right"    : "mode",
            "format": {
                "months":    "<span color='#35b9ab'><b>{}</b></span>",
                "weeks":    "<span color='#73ba25'><b>{}</b></span>",
                "weekdays": "<span color='#21a4df'><b>{}</b></span>",
                "today":    "<span color='#21a4df'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right"    : "mode",
            "on-scroll-up"      : "shift_up",
            "on-scroll-down"      : "shift_down"
        },
        "interval": 1
    },
    "cpu": {
        "format": "{usage}% ´őŤ",
        "tooltip": true,
        "interval": 1
    },
    "memory": {
        "format": "{}% ´âë",
        "interval": 1
    },
    "disk": {
	      "interval": 1,
	      "format": "{specific_free:0.2f} GB / {specific_total:0.2f} GB",
	      "unit": "GB"
    },
    "temperature#cpu": {
        "thermal-zone": 1,
        "critical-threshold": 60,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Łź", "´őë", "´Łę"]
    },
    "temperature#gpu": {
        "hwmon-path": "/sys/class/hwmon/hwmon8/temp1_input",
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Łź", "´őë", "´Łę"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["´ćů", "´äĹ"]
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "´Śž",
        "format-plugged": "´çŽ",
        "format-alt": "{capacity}% {time}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "network": {
        "format-wifi": "´çź  {essid} ({signalStrength}%)",
        "format-ethernet": "´Ť┐",
        "format-linked": "´×ľ",
        "format-disconnected": "ÔÜá",
        "tooltip-format-wifi": "{ifname} {essid} ({signalStrength}%) ´çź",
        "tooltip-format-ethernet": "{ifname} ´âü",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },
    "pulseaudio": {
        "format": "{volume} {icon}",
        "format-alt": "{volume} {icon}",
        "format-alt-click": "click-right",
        "format-muted": "´Üę",
        "format-icons": {
            "headphones": "´Çą",
            "handsfree": "´ľÉ",
            "headset": "´ľÉ",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": true
    },
    "custom/scratchpad": {
        "format-text": "{}",
        "return-type": "json",
        "interval": 3,
        "exec": "/usr/share/openSUSEway/helpers/scratchpad-indicator.sh 2> /dev/null",
        "exec-if": "exit 0",
        "on-click": "swaymsg 'scratchpad show'",
        "on-click-right": "swaymsg 'move scratchpad'"
    },
    "custom/notification": {
	      "tooltip": true,
	      "format": "{icon}",
	      "format-icons": {
	           "notification": "´éó<span foreground='red'><small><sup>ÔČĄ</sup></small></span>",
	           "none": "´éó ",
	           "dnd-notification": "´çĚ<span foreground='red'><small><sup>ÔČĄ</sup></small></span>",
	           "dnd-none": "´çĚ "
  	    },
      	"return-type": "json",
      	"exec-if": "which swaync-client",
      	"exec": "swaync-client -swb",
      	"on-click": "swaync-client -t -sw",
      	"on-click-right": "swaync-client -d -sw",
      	"escape": true
    }
}
